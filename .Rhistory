action_edge_dt <- which.min(df_edge_ed_dt[,4])
explored_node_dt <- c(explored_node_dt, df_edge_ed_dt$outside_vertex[action_edge_dt])
#consider all candiates and let inf if some doesn't cross
fDT_order <- order(df_edge_ed_dt[, 4])
########
#END: fDT finding optimal action
########
######################
obs_ind_temp <- which(Int_info[action_edge_dt,]==1)
if (length(obs_ind_temp)!=0){
if (length(obs_ind_temp)==1){
#
if(obs_info$status[obs_ind_temp]==1){
# adjust based on true obstalce
df_edge_ed_dt[which(Int_info[,obs_ind_temp]==1),3] <- Inf
} else{
# adjust based on false obstacle
df_edge_ed_dt[which(Int_info[,obs_ind_temp]==1),3] <- pmax(0, df_edge_ed_dt[which(Int_info[,obs_ind_temp]==1),3]-
0.5*(obs_info[obs_ind_temp,3]+(dt/(1-obs_info[obs_ind_temp,4]))^(-log(1-obs_info[obs_ind_temp,4]))))
Int_info[which(Int_info[,obs_ind_temp]==1),obs_ind_temp] <- 0
}
} else{
dist_temp <- rep(0,length(obs_ind_temp))
for(i in 1:length(obs_ind_temp)){
dist_temp[i] <- Dist_Euclidean(as.numeric(vertice_list[as.numeric(df_edge_ed_dt[action_edge_dt, 1]), 1:2]),obs_info[obs_ind_temp[i],1:2])
}
obs_ind_temp2 <- obs_ind_temp[which.min(dist_temp)]
# add cost of disambiguation
if (obs_info$status[obs_ind_temp2]==1){
# true obstacle
df_edge_ed_dt[which(Int_info[,obs_ind_temp2]==1),3] <- Inf
} else{
# false obstacle
df_edge_ed_dt[which(Int_info[,obs_ind_temp2]==1),3] <- pmax(0, df_edge_ed_dt[which(Int_info[,obs_ind_temp2]==1),3]-
0.5*(obs_info[obs_ind_temp2,3]+(dt/(1-obs_info[obs_ind_temp2,4]))^(-log(1-obs_info[obs_ind_temp2,4]))))
Int_info[which(Int_info[,obs_ind_temp2]==1),obs_ind_temp2] <- 0
}
}
}
#################
rho <- c(rho, cor(DT_order, fDT_order, method = "spearman"))
